# ============================================
# Portfolio Environment Variables
# Copy this file to .env and fill in your values
# ============================================

# MongoDB Connection String
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/portfolio?retryWrites=true&w=majority

# JWT Secret for Admin Authentication (change this to a random string)
JWT_SECRET=your_super_secret_jwt_key_change_this

# Admin Credentials
ADMIN_USERNAME=your_admin_email@example.com
ADMIN_PASSWORD=your_admin_password

# API URL (change for production)
# For local development:
NEXT_PUBLIC_API_URL=http://localhost:5000/api
# For production (update with your actual backend URL):
# NEXT_PUBLIC_API_URL=https://your-backend-url.onrender.com/api

# Optional: OpenAI API Key
OPENAI_API_KEY=your_openai_api_key_here
